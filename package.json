{
  "name": "paperhall",
  "version": "0.1.0",
  "private": true,
  "description": "A quiet, curated personal library where reading feels like opening a real book at a library table.",
  "scripts": {
    "dev": "next dev -p 3080",
    "build": "next build",
    "start": "next start -p 3080",
    "lint": "next lint",
    "db:setup": "prisma migrate dev --name init && prisma generate",
    "db:reset": "prisma migrate reset --force && prisma generate",
    "db:studio": "prisma studio",
    "import:books": "tsx scripts/import-books.ts",
    "import:books:refresh": "tsx scripts/import-books.ts --refresh",
    "import:books:limit": "tsx scripts/import-books.ts --limit"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "next": "^15.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
